@startuml
title Mode Selection Sequence

actor User
participant "Input Interface" as input3
participant "Mode Controller" as mode3
participant "Processing Engine" as processing3
participant "Output Engine" as output3

User -> input3 : provide situation
input3 -> mode3 : risk, time, conflict,\nevidence, user state
mode3 -> mode3 : compute scores
mode3 --> input3 : selected mode
input3 -> processing3 : run according to mode
processing3 -> output3 : draft result

alt light mode
  output3 --> User : guidance + next steps
else hybrid mode
  output3 --> User : structured guidance + evidence links
else strict mode
  output3 --> User : obligations + deadlines + fallback
end
@enduml

@startuml
title Obligation Lifecycle and Monitoring

start

:Alignment identifies unmet need;
:Create obligation;
:Assign actor;
:Set deadline and fallback;
:Display in strict panel and operations dashboard;

if (completed before deadline?) then (yes)
  :Mark completed;
  :Log audit event;
else (no)
  :Mark breached;
  :Trigger escalation;
  :Log breach and escalation;
endif

stop
@enduml
