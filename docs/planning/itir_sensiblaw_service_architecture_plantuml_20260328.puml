@startuml
title Obligation Assignment and Escalation

actor User
participant "Input Interface" as IN
participant "Alignment Engine" as AE
participant "Obligation Layer" as OL
participant "Output Engine" as OE
participant "Governance Layer" as GL

User -> IN : provide evidence and narrative
IN -> AE : structured case
AE -> OL : unmet need, actor candidates,\nrisk, context
OL -> OL : assign responsibility,\ndeadline, fallback
OL -> GL : check policy and escalation rules
GL --> OL : approved / review required
OL -> OE : obligation object
OE --> User : next action, actor,\ndeadline, fallback

alt missed deadline
  OL -> GL : breach event
  GL -> OL : escalation target
  OL -> OE : escalated action set
  OE --> User : escalation notice
end
@enduml

@startuml
title Obligation Lifecycle

start

:Create obligation;
:Assign actor;
:Set deadline;

if (Action completed?) then (yes)
  :Mark done;
else (no)
  if (Deadline passed?) then (yes)
    :Mark breach;
    :Trigger escalation;
  endif
endif

stop
@enduml

@startuml
title Mode Controller - Container Alignment

left to right direction

rectangle "ITIR / SensibLaw" {
  component "Input Interface" as IN
  component "Alignment Engine" as AE
  component "Mode Controller" as MC
  component "Obligation Layer" as OL
  component "Output Engine" as OE
  component "Governance Layer" as GL
}

IN --> AE : risk, time, conflict,\nevidence, user state
AE --> MC : confirmed context
MC --> OE : mode = light / hybrid / strict
MC --> OL : activate obligation handling\nfor hybrid / strict
MC --> GL : enforcement level
GL --> MC : guardrails / policy
OE --> User : guidance or obligations
@enduml

@startuml
title Everyday UX Flow

start

:Quick capture;
:Auto-select mode;

if (Light?) then (yes)
  :Show "What this looks like";
  :Show "What matters";
  :Show "What to do next";
  if (Need more depth?) then (yes)
    :Show evidence / timeline / graph;
  endif
  if (Need stricter handling?) then (yes)
    :Switch to Hybrid or Strict;
  endif
else (strict or hybrid)
  :Show obligations list;
  :Show deadlines and fallback;
  :Offer generate / notify / escalate;
endif

:Trust controls always visible;
stop
@enduml

