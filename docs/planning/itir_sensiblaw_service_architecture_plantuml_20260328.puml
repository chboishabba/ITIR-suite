@startuml
title ITIR / SensibLaw - Container Diagram

left to right direction

actor User
actor Reviewer

rectangle "ITIR / SensibLaw" {
  component "Input Interface" as IN
  component "Processing Engine" as PE
  component "Promotion Core" as PC
  component "Identity Engine" as IE
  component "Graph Engine" as GE
  component "Derived Legal Follow Graph" as LG
  component "Alignment Engine" as AE
  component "Obligation Layer" as OL
  component "Output Engine" as OE
  component "Governance Layer" as GL
  component "Anti-Panopticon / Red-Team Guard" as AP
}

database "Evidence Store" as ES
database "Graph Store" as GS
database "Audit Store" as AS

User --> IN : uploads narrative,\ndocuments, audio, goals
IN --> PE : normalized inputs
PE --> ES : structured evidence
PE --> PC : extracted candidates
PC --> GE : promoted facts, rules, atoms
GE --> LG : derived legal / claim graph
LG --> OE : graph products
IN --> IE : context, trust, friction, goals
IE --> GE : identity atoms
GE --> GS : legal graph + identity graph
GE --> AE : graph views
AE --> OL : needs, conflicts,\nactions required
OL --> OE : actor, deadline,\nfallback, status
OE --> User : reports, next actions,\ncase views

GL --> PE : policy controls
GL --> PC : anti-panopticon + promotion rules
GL --> IE : trust constraints
GL --> GE : derived graph constraints
GL --> OL : escalation policy
GL --> AS : audit trail
AP --> GL : refusal constraints,\nred-team checks
AP --> GE : anti-overclaim guard
AP --> OE : descriptive-only limits

Reviewer --> GL : review, correction,\nexception handling
@enduml

@startuml
title Container Model (Compact)

actor User

rectangle "ITIR System" {
  component Input
  component Processing
  component Identity
  component Graph
  component Alignment
  component ModeController
  component ObligationLayer
  component Output
  component Governance
}

database Evidence
database GraphStore
database Audit

User --> Input
Input --> Processing
Processing --> Evidence
Input --> Identity
Identity --> Graph
Processing --> Graph
Graph --> GraphStore
Graph --> Alignment
Alignment --> ModeController
ModeController --> ObligationLayer
ObligationLayer --> Output
Output --> User
Governance --> Audit
Governance --> ModeController
Governance --> ObligationLayer
@enduml

@startuml
title Standard Case Flow

start

:Case intake;
:Classify case type;
:Assess risk and urgency;
:Collect evidence and narrative;

fork
  :Extract facts, rules, atoms;
fork again
  :Extract identity, trust,\nfriction, goals;
end fork

:Build legal graph;
:Build identity/trust graph;
:Align graphs;
:Detect gaps and conflicts;
:Create obligations;
:Assign actor, deadline,\nfallback;
:Generate outputs;

if (Safe and accepted?) then (yes)
  :Monitor execution and SLA;
else (no)
  :Escalate to review;
  :Correct and reissue;
endif

stop
@enduml

@startuml
title Mode Selection

start

:Assess risk;
:Assess time pressure;
:Assess conflict;
:Assess evidence;
:Assess user state;

if (High risk OR urgent time OR adversarial conflict?) then (yes)
  :Strict Mode;
else (no)
  if (Moderate signals?) then (yes)
    :Hybrid Mode;
  else (no)
    :Light Mode;
  endif
endif

stop
@enduml

@startuml
title Standard Flow (Compact)

start

:Input case;
:Classify signals;
:Select mode;
:Extract facts;
:Extract identity patterns;
:Build graphs;
:Align graphs;

if (Strict or Hybrid?) then (yes)
  :Create obligations;
endif

:Generate output;

if (Breach?) then (yes)
  :Escalate;
endif

stop
@enduml

