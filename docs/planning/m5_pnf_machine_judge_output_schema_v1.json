{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itir.local/schemas/m5_pnf_machine_judge_output_v1.json",
  "title": "M5 PNF Machine Judge Output v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "query_id",
    "answer_id",
    "arm",
    "run_index",
    "claim_count",
    "supported_claims",
    "partial_claims",
    "unsupported_claims",
    "contradicted_claims",
    "relevance",
    "grounding",
    "completeness",
    "hallucination_rate",
    "residual_laundering_rate",
    "citation_support_rate",
    "governance_violations",
    "residual_profile_distribution"
  ],
  "properties": {
    "query_id": {
      "type": "string",
      "minLength": 1
    },
    "answer_id": {
      "type": "string",
      "minLength": 1
    },
    "arm": {
      "type": "string",
      "enum": ["baseline", "treatment"]
    },
    "run_index": {
      "type": "integer",
      "minimum": 1
    },
    "claim_count": {
      "type": "integer",
      "minimum": 0
    },
    "supported_claims": {
      "type": "integer",
      "minimum": 0
    },
    "partial_claims": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_claims": {
      "type": "integer",
      "minimum": 0
    },
    "contradicted_claims": {
      "type": "integer",
      "minimum": 0
    },
    "authority_overclaim_count": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_entity_claims": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_temporal_claims": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_causal_claims": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_numeric_claims": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_authority_claims": {
      "type": "integer",
      "minimum": 0
    },
    "relevance": {
      "$ref": "#/$defs/score01"
    },
    "grounding": {
      "$ref": "#/$defs/score01"
    },
    "completeness": {
      "$ref": "#/$defs/score01"
    },
    "hallucination_rate": {
      "$ref": "#/$defs/score01"
    },
    "residual_laundering_rate": {
      "$ref": "#/$defs/score01"
    },
    "citation_support_rate": {
      "$ref": "#/$defs/score01"
    },
    "citation_present_rate": {
      "$ref": "#/$defs/score01"
    },
    "citation_precision": {
      "$ref": "#/$defs/score01"
    },
    "citation_overload_rate": {
      "$ref": "#/$defs/score01"
    },
    "rfp_composite_quality_score": {
      "$ref": "#/$defs/score01"
    },
    "retrieval_latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "answer_latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "total_latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cost_estimate": {
      "type": "number",
      "minimum": 0
    },
    "successful_processing": {
      "type": "boolean"
    },
    "governance_violations": {
      "type": "integer",
      "minimum": 0
    },
    "governance_hard_fail_flags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promotion_authority": {"type": "boolean"},
        "routing": {"type": "boolean"},
        "semantic_fact_emission": {"type": "boolean"},
        "surface_ref_implies_truth": {"type": "boolean"},
        "candidate_axis_support_implies_truth": {"type": "boolean"},
        "answer_quality_implies_promotion": {"type": "boolean"}
      }
    },
    "residual_profile_distribution": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "lexical": {"$ref": "#/$defs/residualCounts"},
        "predicate": {"$ref": "#/$defs/residualCounts"},
        "role": {"$ref": "#/$defs/residualCounts"},
        "temporal": {"$ref": "#/$defs/residualCounts"},
        "domain": {"$ref": "#/$defs/residualCounts"},
        "surface": {"$ref": "#/$defs/residualCounts"},
        "authority": {"$ref": "#/$defs/residualCounts"},
        "projection_grade": {"$ref": "#/$defs/residualCounts"}
      }
    },
    "claim_judgments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "claim_id",
          "claim_text",
          "pnf",
          "best_support_comparison"
        ],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "claim_text": {"type": "string"},
          "pnf": {"$ref": "#/$defs/pnfCarrier"},
          "best_support_ref": {"type": ["string", "null"]},
          "best_support_comparison": {
            "type": "string",
            "enum": [
              "exact",
              "partial_compatible",
              "contradicted",
              "unsupported",
              "not_applicable"
            ]
          },
          "residual_profile": {"$ref": "#/$defs/residualProfile"}
        }
      }
    }
  },
  "$defs": {
    "score01": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "residualCounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact": {"type": "integer", "minimum": 0},
        "compatible": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "unresolved": {"type": "integer", "minimum": 0}
      }
    },
    "residualProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lexical": {"$ref": "#/$defs/residualValue"},
        "predicate": {"$ref": "#/$defs/residualValue"},
        "role": {"$ref": "#/$defs/residualValue"},
        "temporal": {"$ref": "#/$defs/residualValue"},
        "domain": {"$ref": "#/$defs/residualValue"},
        "surface": {"$ref": "#/$defs/residualValue"},
        "authority": {"$ref": "#/$defs/residualValue"},
        "projection_grade": {"$ref": "#/$defs/residualValue"}
      }
    },
    "residualValue": {
      "type": "string",
      "enum": ["exact", "compatible", "blocked", "unresolved"]
    },
    "pnfCarrier": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "predicate",
        "roles",
        "qualifiers",
        "time",
        "modality",
        "polarity",
        "source_posture"
      ],
      "properties": {
        "predicate": {"type": "string"},
        "roles": {"type": "object"},
        "qualifiers": {"type": "object"},
        "time": {"type": ["string", "null"]},
        "modality": {"type": "string"},
        "polarity": {"type": "string"},
        "source_posture": {"type": "string"}
      }
    }
  }
}
