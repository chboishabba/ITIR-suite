{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Entity",
  "type": "object",
  "required": ["id", "label", "type", "provenance", "confidence"],
  "properties": {
    "id": { "type": "string" },
    "label": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["PERSON", "ORGANIZATION", "PLACE", "COLLECTIVE_ROLE", "EVENT", "LEGAL_INSTRUMENT", "ABSTRACT"]
    },
    "provenance": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "type": "string", "enum": ["wikilink", "ontology", "registry"] },
        "ref": { "type": "string" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}

