{
  "name": "itir-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:stable": "node --max-old-space-size=3072 ./node_modules/vite/bin/vite.js dev",
    "dev:clean": "rm -rf node_modules/.vite .svelte-kit/output && echo \"cleaned vite cache + ssr output\"",
    "dev:profile": "ITIR_TRACE_MEM=1 node --max-old-space-size=6144 --trace-gc --trace-gc-verbose --heapsnapshot-near-heap-limit=2 ./node_modules/vite/bin/vite.js dev",
    "build": "vite build",
    "preview": "vite preview",
    "ssr:smoke": "node scripts/ssr_smoke.mjs",
    "postinstall": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "echo 'no lint configured'",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.2.0",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/types": "^8.14.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "zod": "^3.23.8"
  }
}
