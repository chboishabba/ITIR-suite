{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZelphInput",
  "type": "object",
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fact_id": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "arguments": {
            "type": "object"
          },
          "qualifiers": {
            "type": "object"
          },
          "confidence": {
            "type": "number"
          },
          "provenance": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "doc_id": {
                  "type": "string"
                },
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                }
              },
              "required": [
                "doc_id",
                "start",
                "end"
              ]
            }
          },
          "promotion_receipt": {
            "type": [
              "string",
              "null"
            ]
          },
          "reconstructible": {
            "type": "boolean"
          },
          "parse_tree": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "sents": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            },
            "required": [
              "text",
              "sents"
            ]
          }
        },
        "required": [
          "fact_id",
          "predicate",
          "arguments",
          "provenance"
        ]
      }
    },
    "semantic_overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "zos_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "members": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "features": {
            "type": "object"
          },
          "candidate_score": {
            "type": "number"
          },
          "promoted": {
            "type": "boolean"
          },
          "source_receipts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "zos_id",
          "kind",
          "members",
          "features",
          "candidate_score",
          "promoted"
        ]
      }
    },
    "provenance_mode": {
      "type": "string",
      "enum": [
        "strict"
      ]
    }
  },
  "required": [
    "facts"
  ]
}
